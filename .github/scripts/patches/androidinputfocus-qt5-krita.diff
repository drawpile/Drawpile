+    private void ensureEditTextView()
+    {
+        if (m_editText == null) {
+            // Integer overflow in Java is well-defined, it wraps around. This
+            // is fine for our purposes, we just want a unique id for the sake
+            // of synchronization.
+            m_editText = new QtEditText(m_activity, this, m_nextEditTextId++, System.getenv("KRITA_ANDROID_EDIT_TEXT_DEBUG_DRAW") != null);
+        }
+    }
+
+    private void removeEditTextView(int editTextId)
+    {
+        if (m_editText != null && m_editText.m_id == editTextId) {
+            if (Build.VERSION.SDK_INT < 33) {
+                m_imm.restartInput(m_editText);
+            } else {
+                m_imm.invalidateInput(m_editText);
+            }
+            m_editText.clearFocus();
+            m_editText.setFocusable(false);
+            m_editText.setFocusableInTouchMode(false);
+            m_layout.removeView(m_editText);
+            m_editText = null;
+            m_layout.requestFocus();
+            m_imm.restartInput(m_layout);
+        }
+    }
 }
